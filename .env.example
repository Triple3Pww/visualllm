# Copy to .env and fill in. Provider selection is by the *_PROVIDER vars.
# The pipeline reads these via pipeline/config.py.

# ---- Stage provider selection --------------------------------------------
# Swap any stage without touching code. See pipeline/stages/*.py for options.
STT_PROVIDER=deepgram          # deepgram | azure | whisper_local | funasr
LLM_PROVIDER=openai            # openai | anthropic | openrouter | qwen_local
TTS_PROVIDER=elevenlabs        # elevenlabs | cartesia | azure | cosyvoice_local | kokoro_local
AVATAR_PROVIDER=simli          # simli | heygen
LANGUAGE=en                    # en | zh   (zh = Mandarin / zh-TW)

# ---- API keys (only the ones for your selected providers are required) ----
DEEPGRAM_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# OpenRouter — one key, any model. Set OPENROUTER_MODEL to choose (e.g.
# openai/gpt-4o-mini, anthropic/claude-haiku-4.5, google/gemini-2.0-flash,
# qwen/qwen-2.5-7b-instruct, deepseek/deepseek-chat).
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# Azure Speech (STT + TTS) — Taiwan-Mandarin contender, https://portal.azure.com
# Region e.g. eastasia / southeastasia for low latency from Taiwan.
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=eastasia
AZURE_TTS_VOICE=               # blank = zh-TW-HsiaoChenNeural (zh) / en-US-AvaNeural (en)

# Cartesia (low-latency TTS) — https://play.cartesia.ai
CARTESIA_API_KEY=
CARTESIA_VOICE_ID=

# Simli (real-time avatar) — get from https://simli.com
SIMLI_API_KEY=
SIMLI_FACE_ID=

# HeyGen LiveAvatar (alternative avatar) — https://developers.heygen.com
HEYGEN_API_KEY=
HEYGEN_AVATAR_ID=

# ---- Local model endpoints (Phase 3) -------------------------------------
COSYVOICE_URL=http://localhost:8001
MUSETALK_URL=http://localhost:8002
QWEN_BASE_URL=http://localhost:8000/v1   # vLLM/Ollama OpenAI-compatible endpoint
# Your own portrait for the free local MuseTalk avatar (read by the server).
AVATAR_REF=assets/avatar.png

# ---- Latency target -------------------------------------------------------
TTFO_TARGET_SECONDS=8
